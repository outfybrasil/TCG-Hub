# Backend / database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tcghub
SECRET_KEY=troque-esta-chave-em-producao

# Frontend (build + runtime)
# Use o dominio publico da sua API (ou IP publico na VPS).
NEXT_PUBLIC_API_URL=http://SEU_IP_OU_DOMINIO:8000/api/v1

# Supabase (obrigatorio para auth, leiloes, pagamento com cashback)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SEU_SUPABASE_ANON_KEY

# Mercado Pago (obrigatorio para rotas /api/pagamento/*)
MP_ACCESS_TOKEN=SEU_MP_ACCESS_TOKEN
